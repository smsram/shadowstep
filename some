// src/components/ControlPanel.tsx
import { useState, useEffect } from 'preact/hooks';

export function ControlPanel() {
  const [isOpen, setIsOpen] = useState(false);
  const [isConfigured, setIsConfigured] = useState(false);
  const [apiKeys, setApiKeys] = useState<string[]>([]);
  const [keyInput, setKeyInput] = useState('');
  
  const [scope, setScope] = useState('all');
  const [logs, setLogs] = useState<string[]>(['System initialized.', 'Awaiting secure connection...']);
  const [inputValue, setInputValue] = useState('');
  const [activeKeyIndex, setActiveKeyIndex] = useState(0);

  // 1. Initial Storage Check
  useEffect(() => {
    if (typeof chrome !== 'undefined' && chrome.storage) {
      chrome.storage.local.get(['apiKeys'], (result) => {
        if (result.apiKeys && Array.isArray(result.apiKeys) && result.apiKeys.length > 0) {
          setApiKeys(result.apiKeys);
          setKeyInput(result.apiKeys.join(', '));
          setIsConfigured(true);
          setLogs(['System initialized.', `Routing engine loaded with ${result.apiKeys.length} nodes.`]);
        }
      });
    }
  }, []);

  // 2. Save and Parse Multiple Keys
  const handleSaveKeys = () => {
    // Split by comma, trim whitespace, remove empty entries
    const parsedKeys = keyInput.split(',').map(k => k.trim()).filter(k => k.length > 0);
    
    if (parsedKeys.length > 0) {
      if (typeof chrome !== 'undefined' && chrome.storage) {
        chrome.storage.local.set({ apiKeys: parsedKeys }, () => {
          setApiKeys(parsedKeys);
          setIsConfigured(true);
          setLogs(['System initialized.', `Routing engine loaded with ${parsedKeys.length} fallback nodes.`]);
        });
      } else {
        // Local browser testing fallback
        setApiKeys(parsedKeys);
        setIsConfigured(true);
      }
    }
  };

  // 3. Fallback Execution Logic Loop
  const handleSend = () => {
    if (!inputValue.trim()) return;
    
    setLogs(prev => [...prev, `User: ${inputValue}`, `Agent: Initiating via Node [${activeKeyIndex + 1}/${apiKeys.length}]...`]);
    setInputValue('');
    
    // Simulate a network execution and random rate-limit failure for visual testing
    setTimeout(() => {
      const willFail = apiKeys.length > 1 && Math.random() > 0.5; // 50% chance to fail if >1 key exists
      
      if (willFail) {
        const nextIndex = (activeKeyIndex + 1) % apiKeys.length;
        setActiveKeyIndex(nextIndex);
        setLogs(prev => [...prev, `System: HTTP 429 Rate Limit hit.`, `Agent: Auto-switching to fallback Node [${nextIndex + 1}/${apiKeys.length}]...`, `Agent: Analyzing viewport coordinates...`]);
      } else {
        setLogs(prev => [...prev, 'Agent: Viewport split verification complete.', 'System: Instruction executed successfully.']);
      }
    }, 1200);
  };

  return (
    <div style={{ fontFamily: 'system-ui, -apple-system, sans-serif', color: '#F5F6F7' }}>
      
      {/* FLOATING TRIGGER ICON */}
      {!isOpen && (
        <div 
          onClick={() => setIsOpen(true)}
          style={{
            position: 'fixed',
            right: 0,
            top: '45%',
            transform: 'translateY(-50%)',
            width: '38px',
            height: '48px',
            backgroundColor: 'rgba(26, 28, 30, 0.85)',
            backdropFilter: 'blur(12px)',
            border: '1px solid rgba(255, 255, 255, 0.08)',
            borderRight: 'none',
            borderRadius: '10px 0 0 10px',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            cursor: 'pointer',
            boxShadow: '-4px 4px 16px rgba(0, 0, 0, 0.3)',
            transition: 'all 0.2s ease',
            zIndex: 999999
          }}
        >
          <span style={{ fontSize: '18px', filter: 'drop-shadow(0 0 4px #00FFC2)' }}>🤖</span>
        </div>
      )}

      {/* EXPANDED GLASSMORPHIC INTERFACE */}
      <div 
        style={{
          position: 'fixed',
          right: isOpen ? '0px' : '-380px',
          top: '0px',
          width: '360px',
          height: '100vh',
          backgroundColor: 'rgba(18, 19, 20, 0.85)',
          backdropFilter: 'blur(20px)',
          borderLeft: '1px solid rgba(255, 255, 255, 0.08)',
          boxShadow: '-10px 0 40px rgba(0, 0, 0, 0.5)',
          transition: 'right 0.25s cubic-bezier(0.16, 1, 0.3, 1)',
          display: 'flex',
          flexDirection: 'column',
          boxSizing: 'border-box',
          padding: '24px',
          zIndex: 999999
        }}
      >
        {/* HEADER */}
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '24px' }}>
          <h2 style={{ margin: 0, fontSize: '18px', fontWeight: 600, letterSpacing: '-0.5px' }}>
            ShadowStep <span style={{ color: '#00FFC2', fontWeight: 300 }}>Agent</span>
          </h2>
          <div style={{ display: 'flex', gap: '12px' }}>
            {isConfigured && (
              <button 
                onClick={() => setIsConfigured(false)}
                style={{ background: 'none', border: 'none', color: '#888', cursor: 'pointer', fontSize: '14px' }}
                title="Configure Keys"
              >
                ⚙️
              </button>
            )}
            <button 
              onClick={() => setIsOpen(false)}
              style={{ background: 'none', border: 'none', color: '#888', cursor: 'pointer', fontSize: '16px' }}
            >
              ✕
            </button>
          </div>
        </div>

        {/* VIEW 1: API CONFIGURATION SCREEN */}
        {!isConfigured ? (
          <div style={{ flex: 1, display: 'flex', flexDirection: 'column', justifyContent: 'center' }}>
            <h3 style={{ fontSize: '14px', margin: '0 0 8px', color: '#FFF' }}>Security Authorization</h3>
            <p style={{ fontSize: '12px', color: '#888', margin: '0 0 20px', lineHeight: '1.5' }}>
              Enter your Groq or SiliconFlow API keys to activate the agent. Separate multiple keys with commas for automatic failover.
            </p>
            
            <textarea
              placeholder="gsk_12345..., sk-fast-6789..."
              value={keyInput}
              onInput={(e) => setKeyInput((e.target as HTMLTextAreaElement).value)}
              style={{
                width: '100%',
                height: '100px',
                backgroundColor: 'rgba(255, 255, 255, 0.04)',
                border: '1px solid rgba(255, 255, 255, 0.08)',
                borderRadius: '8px',
                padding: '12px',
                color: '#FFF',
                fontSize: '12px',
                fontFamily: 'monospace',
                outline: 'none',
                resize: 'none',
                marginBottom: '16px',
                boxSizing: 'border-box'
              }}
            />
            
            <button
              onClick={handleSaveKeys}
              style={{
                width: '100%',
                backgroundColor: '#00FFC2',
                color: '#121314',
                border: 'none',
                borderRadius: '8px',
                padding: '12px 0',
                fontWeight: 600,
                fontSize: '13px',
                cursor: 'pointer',
                boxShadow: '0 4px 20px rgba(0, 255, 194, 0.15)'
              }}
            >
              Initialize Engine
            </button>
          </div>
        ) : (
          
        /* VIEW 2: ACTIVE AGENT TERMINAL */
          <div style={{ flex: 1, display: 'flex', flexDirection: 'column' }}>
            
            {/* SCOPE SELECTOR */}
            <div style={{ 
              display: 'flex', 
              backgroundColor: 'rgba(255, 255, 255, 0.03)', 
              borderRadius: '8px', 
              padding: '3px', 
              border: '1px solid rgba(255, 255, 255, 0.04)',
              marginBottom: '16px'
            }}>
              {['all', 'domain', 'session'].map((item) => (
                <button
                  key={item}
                  onClick={() => setScope(item)}
                  style={{
                    flex: 1,
                    background: scope === item ? 'rgba(255, 255, 255, 0.08)' : 'none',
                    border: 'none',
                    color: scope === item ? '#FFF' : '#888',
                    padding: '6px 0',
                    fontSize: '11px',
                    borderRadius: '6px',
                    cursor: 'pointer',
                    transition: 'all 0.15s ease'
                  }}
                >
                  {item === 'all' ? 'All Pages' : item === 'domain' ? 'This Site' : 'Once'}
                </button>
              ))}
            </div>

            {/* LIVE ACTIVITY LOG */}
            <div style={{
              flex: 1,
              backgroundColor: 'rgba(255, 255, 255, 0.02)',
              border: '1px solid rgba(255, 255, 255, 0.05)',
              borderRadius: '12px',
              padding: '16px',
              overflowY: 'auto',
              fontSize: '12px',
              lineHeight: '1.6',
              color: '#C9CDD0',
              display: 'flex',
              flexDirection: 'column',
              gap: '8px',
              marginBottom: '20px'
            }}>
              {logs.map((log, i) => (
                <div key={i} style={{ 
                  borderBottom: '1px solid rgba(255, 255, 255, 0.02)', 
                  paddingBottom: '4px',
                  color: log.startsWith('User:') ? '#888' : log.startsWith('System') ? '#FFB703' : '#00FFC2'
                }}>
                  {log}
                </div>
              ))}
            </div>

            {/* INSTRUCTION INPUT */}
            <div style={{ position: 'relative' }}>
              <input 
                type="text" 
                placeholder="Instruct agent..." 
                value={inputValue}
                onInput={(e) => setInputValue((e.target as HTMLInputElement).value)}
                onKeyDown={(e) => e.key === 'Enter' && handleSend()}
                style={{
                  width: '100%',
                  backgroundColor: 'rgba(255, 255, 255, 0.04)',
                  border: '1px solid rgba(255, 255, 255, 0.08)',
                  borderRadius: '8px',
                  padding: '12px 40px 12px 12px',
                  boxSizing: 'border-box',
                  color: '#FFF',
                  fontSize: '13px',
                  outline: 'none',
                  transition: 'border-color 0.2s ease'
                }}
                onFocus={(e) => (e.target as HTMLInputElement).style.borderColor = 'rgba(0, 255, 194, 0.4)'}
                onBlur={(e) => (e.target as HTMLInputElement).style.borderColor = 'rgba(255, 255, 255, 0.08)'}
              />
              <button 
                onClick={handleSend}
                style={{
                  position: 'absolute',
                  right: '8px',
                  top: '50%',
                  transform: 'translateY(-50%)',
                  background: 'none',
                  border: 'none',
                  color: '#00FFC2',
                  fontSize: '16px',
                  cursor: 'pointer'
                }}
              >
                ↵
              </button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}


