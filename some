// src/app.tsx
import { useState, useEffect } from 'preact/hooks';

interface StorageResult {
  apiKey?: string;
}

export function App() {
  const [apiKey, setApiKey] = useState('');
  const [savedStatus, setSavedStatus] = useState('');

  // Combined & cleaned into a single type-safe hook
  useEffect(() => {
    if (typeof chrome !== 'undefined' && chrome.storage) {
      chrome.storage.local.get(['apiKey'], (result: StorageResult) => {
        if (result && typeof result.apiKey === 'string') {
          setApiKey(result.apiKey);
        }
      });
    }
  }, []);

  const saveConfiguration = () => {
    if (typeof chrome !== 'undefined' && chrome.storage) {
      chrome.storage.local.set({ apiKey }, () => {
        setSavedStatus('Configuration Saved ✔');
        setTimeout(() => setSavedStatus(''), 2000);
      });
    } else {
      setSavedStatus('Local storage missing');
    }
  };

  return (
    <div style={{
      fontFamily: 'system-ui, sans-serif',
      backgroundColor: '#121314',
      color: '#F5F6F7',
      minHeight: '100vh',
      padding: '40px 20px',
      boxSizing: 'border-box',
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center'
    }}>
      <div style={{
        width: '100%',
        maxWidth: '480px',
        backgroundColor: 'rgba(26, 28, 30, 0.45)',
        backdropFilter: 'blur(16px)',
        border: '1px solid rgba(255, 255, 255, 0.08)',
        borderRadius: '16px',
        padding: '32px',
        boxShadow: '0 20px 40px rgba(0,0,0,0.5)'
      }}>
        <h1 style={{ fontSize: '24px', fontWeight: 600, margin: '0 0 8px 0', letterSpacing: '-0.5px' }}>
          ShadowStep <span style={{ color: '#00FFC2', fontWeight: 300 }}>Control Desk</span>
        </h1>
        <p style={{ color: '#888', fontSize: '13px', margin: '0 0 32px 0' }}>
          Configure core routing engine parameters and security metrics.
        </p>

        <div style={{ marginBottom: '24px', width: '100%' }}>
          <label style={{ display: 'block', fontSize: '11px', color: '#aaa', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: '8px' }}>
            ENGINE LLM API KEY
          </label>
          <input 
            type="password" 
            placeholder="sk-proj-........................"
            value={apiKey}
            onInput={(e) => setApiKey((e.target as HTMLInputElement).value)}
            style={{
              width: '100%',
              backgroundColor: 'rgba(255, 255, 255, 0.04)',
              border: '1px solid rgba(255, 255, 255, 0.08)',
              borderRadius: '8px',
              padding: '12px',
              color: '#FFF',
              fontSize: '14px',
              outline: 'none',
              boxSizing: 'border-box'
            }}
          />
        </div>

        <button
          onClick={saveConfiguration}
          style={{
            width: '100%',
            backgroundColor: '#00FFC2',
            color: '#121314',
            border: 'none',
            borderRadius: '8px',
            padding: '12px 0',
            fontWeight: 600,
            fontSize: '14px',
            cursor: 'pointer',
            boxShadow: '0 4px 20px rgba(0, 255, 194, 0.15)',
            transition: 'transform 0.1s ease'
          }}
        >
          Save Core Metrics
        </button>

        {savedStatus && (
          <div style={{ textAlign: 'center', fontSize: '12px', color: '#00FFC2', marginTop: '16px' }}>
            {savedStatus}
          </div>
        )}
      </div>
    </div>
  );
}


